---
export interface Props {
  title: string;
  description: string;
  lang?: 'es' | 'en';
  canonical?: string;
  image?: string;
}

const { title, description, lang = 'es', canonical = 'https://vigia.dev', image = '/og-image.jpg' } = Astro.props;
const locale = lang === 'en' ? 'en_US' : 'es_CO';
const alternateLang = lang === 'en' ? 'es' : 'en';
const alternateUrl = 'https://vigia.dev';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#121212" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow, max-snippet:150, max-image-preview:large" />

    <title>{title}</title>

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <link rel="alternate" hreflang={lang} href={canonical} />
    <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href="https://vigia.dev" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`https://vigia.dev${image}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={locale} />
    <meta property="og:site_name" content="VigIA" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://vigia.dev${image}`} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "VigIA",
      "url": "https://vigia.dev",
      "logo": "https://vigia.dev/favicon.svg",
      "description": description,
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "info@vigia.dev",
        "contactType": "sales"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "VigIA",
      "operatingSystem": "Linux (Ubuntu/Debian)",
      "applicationCategory": "SecurityApplication",
      "description": description,
      "url": "https://vigia.dev"
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "VigIA",
      "url": "https://vigia.dev",
      "description": description
    })} />
  </head>
  <body>
    <!-- Skip link for keyboard navigation -->
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

    <!-- Scroll Progress Bar -->
    <div id="scroll-progress" class="scroll-progress" role="progressbar" aria-label="Progreso de lectura" aria-hidden="true"></div>

    <!-- Scanline overlay for cinematic feel -->
    <div class="scanline-overlay" aria-hidden="true"></div>

    <!-- Custom crosshair cursor -->
    <svg
      class="cursor-crosshair"
      id="custom-cursor"
      width="40"
      height="40"
      viewBox="0 0 40 40"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <!-- Tactical cross -->
      <line x1="20" y1="0" x2="20" y2="14" stroke="#00FF88" stroke-width="1.25" opacity="0.9" />
      <line x1="20" y1="26" x2="20" y2="40" stroke="#00FF88" stroke-width="1.25" opacity="0.9" />
      <line x1="0" y1="20" x2="14" y2="20" stroke="#00FF88" stroke-width="1.25" opacity="0.9" />
      <line x1="26" y1="20" x2="40" y2="20" stroke="#00FF88" stroke-width="1.25" opacity="0.9" />
      <!-- Center dot -->
      <circle cx="20" cy="20" r="2.5" fill="#00FF88" opacity="1" />
      <!-- Corner brackets -->
      <path d="M8 4 L4 4 L4 8" stroke="#00FF88" stroke-width="1.5" fill="none" opacity="0.7" />
      <path d="M32 4 L36 4 L36 8" stroke="#00FF88" stroke-width="1.5" fill="none" opacity="0.7" />
      <path d="M8 36 L4 36 L4 32" stroke="#00FF88" stroke-width="1.5" fill="none" opacity="0.7" />
      <path d="M32 36 L36 36 L36 32" stroke="#00FF88" stroke-width="1.5" fill="none" opacity="0.7" />
    </svg>

    <slot />

    <style>
      html {
        scrollbar-width: thin;
        scrollbar-color: var(--color-cobalt) var(--color-carbon);
      }
    </style>
  </body>
</html>
