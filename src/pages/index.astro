---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { translations } from "../i18n/translations";
const es = translations.es;
const en = translations.en;
---

<Layout title={es.seo.title} description={es.seo.description} lang="es">
  <!-- ═══════ NAVBAR ═══════ -->
  <nav
    id="navbar"
    aria-label="Navegación principal"
    class="fixed top-0 left-0 w-full z-[9000] transition-all duration-300"
    style="background:rgba(14,14,16,0.8);backdrop-filter:blur(16px);border-bottom:1px solid rgba(0,85,255,0.06);"
  >
    <div class="flex items-center justify-between max-w-6xl mx-auto px-8 py-3">
      <!-- Logo -->
      <a
        href="#hero"
        class="flex items-center gap-3 no-underline"
        aria-label="VigIA — Ir al inicio"
      >
        <svg
          width="26"
          height="26"
          viewBox="0 0 32 32"
          fill="none"
          aria-hidden="true"
          ><circle
            cx="16"
            cy="16"
            r="8"
            stroke="#0055FF"
            stroke-width="2"
            fill="none"></circle><circle cx="16" cy="16" r="3" fill="#00FF88"
          ></circle><line
            x1="16"
            y1="4"
            x2="16"
            y2="10"
            stroke="#0055FF"
            stroke-width="1.5"></line><line
            x1="16"
            y1="22"
            x2="16"
            y2="28"
            stroke="#0055FF"
            stroke-width="1.5"></line><line
            x1="4"
            y1="16"
            x2="10"
            y2="16"
            stroke="#0055FF"
            stroke-width="1.5"></line><line
            x1="22"
            y1="16"
            x2="28"
            y2="16"
            stroke="#0055FF"
            stroke-width="1.5"></line></svg
        >
        <span class="font-mono text-lg font-bold tracking-wider text-white"
          >Vig<span class="text-gradient-cobalt">IA</span></span
        >
      </a>

      <!-- Nav Links (desktop) -->
      <div
        class="hidden md:flex items-center gap-12 font-mono text-[11px] tracking-[0.2em] uppercase"
        role="list"
      >
        <a
          href="#engine"
          class="nav-link text-ghost hover:text-cobalt transition-colors py-2 px-1"
          role="listitem"
          data-i18n-es={es.nav.engine}
          data-i18n-en={en.nav.engine}>{es.nav.engine}</a
        >
        <a
          href="#integration"
          class="nav-link text-ghost hover:text-cobalt transition-colors py-2 px-1"
          role="listitem"
          data-i18n-es={es.nav.integration}
          data-i18n-en={en.nav.integration}>{es.nav.integration}</a
        >
        <a
          href="#contact"
          class="nav-link text-ghost hover:text-cobalt transition-colors py-2 px-1"
          role="listitem"
          data-i18n-es={es.nav.contact}
          data-i18n-en={en.nav.contact}>{es.nav.contact}</a
        >
      </div>

      <div class="flex items-center gap-5">
        <!-- Language Toggle -->
        <div
          class="lang-toggle"
          id="lang-toggle"
          role="group"
          aria-label="Seleccionar idioma"
        >
          <button
            class="lang-btn active"
            data-lang="es"
            id="btn-es"
            aria-pressed="true">ES</button
          >
          <button
            class="lang-btn"
            data-lang="en"
            id="btn-en"
            aria-pressed="false">EN</button
          >
        </div>
        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden flex flex-col gap-1.5 p-3 min-w-[44px] min-h-[44px] items-center justify-center"
          aria-label="Abrir menú de navegación"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span
            class="block w-5 h-0.5 bg-white transition-all"
            aria-hidden="true"></span>
          <span
            class="block w-5 h-0.5 bg-white transition-all"
            aria-hidden="true"></span>
          <span
            class="block w-3 h-0.5 bg-cobalt transition-all"
            aria-hidden="true"></span>
        </button>
      </div>
    </div>
    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="md:hidden hidden flex-col gap-8 px-6 pb-6 font-mono text-sm uppercase tracking-widest"
      role="menu"
    >
      <a
        href="#engine"
        class="text-ghost hover:text-cobalt nav-link py-3"
        role="menuitem"
        data-i18n-es={es.nav.engine}
        data-i18n-en={en.nav.engine}>{es.nav.engine}</a
      >
      <a
        href="#integration"
        class="text-ghost hover:text-cobalt nav-link py-3"
        role="menuitem"
        data-i18n-es={es.nav.integration}
        data-i18n-en={en.nav.integration}>{es.nav.integration}</a
      >
      <a
        href="#contact"
        class="text-ghost hover:text-cobalt nav-link py-3"
        role="menuitem"
        data-i18n-es={es.nav.contact}
        data-i18n-en={en.nav.contact}>{es.nav.contact}</a
      >
    </div>
  </nav>

  <main id="main-content" tabindex="-1">
    <!-- ═══════ HERO ═══════ -->
    <section
      id="hero"
      class="section-panel relative overflow-hidden"
      style="min-height:100vh;"
    >
      <!-- Video background -->
      <video
        id="hero-video"
        class="absolute inset-0 w-full h-full object-cover"
        style="z-index:0;"
        autoplay
        loop
        muted
        playsinline
        preload="auto"
        aria-hidden="true"
      >
        <source src="/hero_animation.webm" type="video/webm" />
      </video>
      <script>
        document.getElementById("hero-video").playbackRate = 1.75;
      </script>
      <!-- Dark overlay for text readability -->
      <div
        class="absolute inset-0"
        style="background:rgba(14,14,16,0.45);z-index:1;"
      >
      </div>

      <div
        class="section-inner relative z-10 flex flex-col items-start justify-center gap-10"
      >
        <!-- Status badge -->
        <div
          class="flex items-center gap-3 px-4 py-2 rounded-full"
          style="border:1px solid rgba(0,255,136,0.15);background:rgba(0,255,136,0.03);"
        >
          <span class="pulse-dot"></span>
          <span
            class="font-mono text-xs text-emerald tracking-widest i18n"
            data-i18n-es={es.hero.status}
            data-i18n-en={en.hero.status}>{es.hero.status}</span
          >
        </div>

        <!-- Tagline -->
        <p
          class="font-mono text-xs text-cobalt tracking-[0.35em] uppercase i18n"
          data-i18n-es={es.hero.tagline}
          data-i18n-en={en.hero.tagline}
        >
          {es.hero.tagline}
        </p>

        <!-- Main headline -->
        <h1
          class="text-5xl md:text-7xl lg:text-[5.5rem] font-bold leading-[1.05]"
        >
          <span
            class="block text-white-soft i18n"
            id="hero-line-1"
            data-i18n-es={es.hero.headline_1}
            data-i18n-en={en.hero.headline_1}>{es.hero.headline_1}</span
          >
          <span
            class="block text-gradient-cobalt i18n"
            id="hero-line-2"
            data-i18n-es={es.hero.headline_2}
            data-i18n-en={en.hero.headline_2}>{es.hero.headline_2}</span
          >
          <span
            class="block text-white-soft i18n"
            id="hero-line-3"
            data-i18n-es={es.hero.headline_3}
            data-i18n-en={en.hero.headline_3}>{es.hero.headline_3}</span
          >
          <span
            class="block text-gradient-emerald i18n"
            id="hero-line-4"
            data-i18n-es={es.hero.headline_4}
            data-i18n-en={en.hero.headline_4}>{es.hero.headline_4}</span
          >
        </h1>

        <!-- Subtitle -->
        <p
          id="hero-sub"
          class="text-base md:text-xl text-white-soft max-w-xl leading-relaxed i18n drop-shadow-sm"
          data-i18n-es={es.hero.sub}
          data-i18n-en={en.hero.sub}
        >
          {es.hero.sub}
        </p>

        <!-- CTA -->
        <a
          href="#contact"
          id="hero-cta"
          class="inline-flex items-center gap-3 px-8 py-4 font-mono text-sm font-semibold tracking-wider uppercase rounded text-white no-underline"
          style="background:var(--color-cobalt);box-shadow:0 0 30px rgba(0,85,255,0.25);"
        >
          <span
            class="i18n"
            data-i18n-es={es.hero.cta}
            data-i18n-en={en.hero.cta}>{es.hero.cta}</span
          >
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
            ><path
              d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path></svg
          >
        </a>

        <!-- HUD corner decorations -->
        <div
          class="absolute top-24 right-8 hidden lg:block font-mono text-[10px] text-ghost opacity-40"
          aria-hidden="true"
        >
          <div>LAT: 4.7110° N</div>
          <div>LON: 74.0721° W</div>
          <div class="mt-1 text-emerald">FPS: 30 ▪ RES: 640px</div>
        </div>
      </div>
    </section>

    <!-- ═══════ PROBLEM ═══════ -->
    <section id="problem" class="section-panel gpu-layer">
      <div class="section-inner">
        <p
          class="font-mono text-xs text-cobalt tracking-[0.3em] mb-8 i18n"
          data-i18n-es={es.problem.label}
          data-i18n-en={en.problem.label}
        >
          {es.problem.label}
        </p>
        <h2
          class="text-3xl md:text-5xl lg:text-6xl font-bold text-white max-w-4xl leading-tight i18n"
          data-i18n-es={es.problem.title}
          data-i18n-en={en.problem.title}
        >
          {es.problem.title}
        </h2>
        <div class="grid md:grid-cols-2 gap-20 mb-28">
          <p
            class="text-base text-slate leading-[1.8] i18n"
            data-i18n-es={es.problem.p1}
            data-i18n-en={en.problem.p1}
          >
            {es.problem.p1}
          </p>
          <p
            class="text-base text-slate leading-[1.8] i18n"
            data-i18n-es={es.problem.p2}
            data-i18n-en={en.problem.p2}
          >
            {es.problem.p2}
          </p>
        </div>
        <!-- Stats -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="glass-card hud-border text-center p-10 stat-card">
            <div
              class="text-4xl md:text-5xl font-bold text-gradient-cobalt font-mono"
            >
              {es.problem.stat1_num}
            </div>
            <p
              class="text-xs text-ghost mt-4 font-mono tracking-wider i18n"
              data-i18n-es={es.problem.stat1_label}
              data-i18n-en={en.problem.stat1_label}
            >
              {es.problem.stat1_label}
            </p>
          </div>
          <div class="glass-card hud-border text-center p-10 stat-card">
            <div
              class="text-4xl md:text-5xl font-bold text-gradient-emerald font-mono"
            >
              {es.problem.stat2_num}
            </div>
            <p
              class="text-xs text-ghost mt-4 font-mono tracking-wider i18n"
              data-i18n-es={es.problem.stat2_label}
              data-i18n-en={en.problem.stat2_label}
            >
              {es.problem.stat2_label}
            </p>
          </div>
          <div class="glass-card hud-border text-center p-10 stat-card">
            <div
              class="text-4xl md:text-5xl font-bold text-gradient-cobalt font-mono"
            >
              {es.problem.stat3_num}
            </div>
            <p
              class="text-xs text-ghost mt-4 font-mono tracking-wider i18n"
              data-i18n-es={es.problem.stat3_label}
              data-i18n-en={en.problem.stat3_label}
            >
              {es.problem.stat3_label}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════ ENGINE ═══════ -->
    <section id="engine" class="section-panel gpu-layer">
      <div class="section-inner">
        <div class="flex items-center gap-3 mb-8">
          <p
            class="font-mono text-xs text-emerald tracking-[0.3em] i18n"
            data-i18n-es={es.engine.label}
            data-i18n-en={en.engine.label}
          >
            {es.engine.label}
          </p>
          <span class="pulse-dot"></span>
          <span
            class="font-mono text-[10px] text-emerald i18n"
            data-i18n-es={es.engine.pulse}
            data-i18n-en={en.engine.pulse}>{es.engine.pulse}</span
          >
        </div>
        <h2
          class="text-3xl md:text-5xl font-bold text-white mb-6 i18n"
          data-i18n-es={es.engine.title}
          data-i18n-en={en.engine.title}
        >
          {es.engine.title}
        </h2>
        <p
          class="text-base text-slate max-w-xl leading-[1.8] mb-24 i18n"
          data-i18n-es={es.engine.sub}
          data-i18n-en={en.engine.sub}
        >
          {es.engine.sub}
        </p>

        <div class="grid md:grid-cols-2 gap-5">
          {
            [
              {
                t: es.engine.feat1_title,
                d: es.engine.feat1_desc,
                te: en.engine.feat1_title,
                de: en.engine.feat1_desc,
                icon: "M9 3v2M15 3v2M9 21v2M15 21v2M3 9h2M3 15h2M21 9h2M21 15h2M9 7h6v10H9z",
              },
              {
                t: es.engine.feat2_title,
                d: es.engine.feat2_desc,
                te: en.engine.feat2_title,
                de: en.engine.feat2_desc,
                icon: "M3 12h4M17 12h4M12 3v4M12 17v4M12 8a4 4 0 1 0 4 4",
              },
              {
                t: es.engine.feat3_title,
                d: es.engine.feat3_desc,
                te: en.engine.feat3_title,
                de: en.engine.feat3_desc,
                icon: "M11 5L6 9H2v6h4l5 4V5zM19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07",
              },
              {
                t: es.engine.feat4_title,
                d: es.engine.feat4_desc,
                te: en.engine.feat4_title,
                de: en.engine.feat4_desc,
                icon: "M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3zM5 10v2a7 7 0 0 0 14 0v-2M12 19v4",
              },
            ].map((feat) => (
              <div class="glass-card hud-border feat-card group p-8">
                <div class="flex items-start gap-5">
                  <div
                    class="flex-shrink-0 w-10 h-10 rounded flex items-center justify-center"
                    style="background:rgba(0,85,255,0.06);border:1px solid rgba(0,85,255,0.15);"
                  >
                    <svg
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="#0055FF"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d={feat.icon} />
                    </svg>
                  </div>
                  <div class="py-1">
                    <h3
                      class="text-base font-bold text-white mb-3 font-mono i18n"
                      data-i18n-es={feat.t}
                      data-i18n-en={feat.te}
                    >
                      {feat.t}
                    </h3>
                    <p
                      class="text-sm text-slate leading-[1.7] i18n"
                      data-i18n-es={feat.d}
                      data-i18n-en={feat.de}
                    >
                      {feat.d}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ═══════ INTEGRATION ═══════ -->
    <section id="integration" class="section-panel gpu-layer">
      <div class="section-inner">
        <p
          class="font-mono text-xs text-cobalt tracking-[0.3em] mb-8 i18n"
          data-i18n-es={es.integration.label}
          data-i18n-en={en.integration.label}
        >
          {es.integration.label}
        </p>
        <h2
          class="text-3xl md:text-5xl font-bold text-white mb-6 i18n"
          data-i18n-es={es.integration.title}
          data-i18n-en={en.integration.title}
        >
          {es.integration.title}
        </h2>
        <p
          class="text-base text-slate max-w-xl leading-[1.8] mb-16 i18n"
          data-i18n-es={es.integration.sub}
          data-i18n-en={en.integration.sub}
        >
          {es.integration.sub}
        </p>

        <!-- Flow Pipeline -->
        <div class="flex flex-wrap items-center justify-center gap-4 mb-20">
          {
            es.integration.flow.map((step, i) => (
              <div class="flex items-center gap-4 flow-step">
                <div
                  class="glass-card px-7 py-4 font-mono text-sm text-white text-center"
                  style={`border-color:${i === 2 ? "rgba(0,255,136,0.2)" : "rgba(0,85,255,0.12)"};`}
                >
                  <span class="text-[10px] text-ghost block mb-1.5">
                    0{i + 1}
                  </span>
                  <span
                    class="i18n"
                    data-i18n-es={es.integration.flow[i]}
                    data-i18n-en={en.integration.flow[i]}
                  >
                    {step}
                  </span>
                </div>
                {i < 3 && (
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 20 20"
                    fill="none"
                    class="text-cobalt hidden md:block opacity-40"
                    aria-hidden="true"
                  >
                    <path
                      d="M4 10h12M12 6l4 4-4 4"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                )}
              </div>
            ))
          }
        </div>

        <div class="grid md:grid-cols-2 gap-5">
          <!-- Sirena -->
          <div class="glass-card hud-border p-10 integ-card">
            <div class="flex items-center gap-4 mb-5">
              <div
                class="w-10 h-10 rounded flex items-center justify-center"
                style="background:rgba(255,85,85,0.06);border:1px solid rgba(255,85,85,0.15);"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#FF5555"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"
                  ></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path><line
                    x1="12"
                    y1="2"
                    x2="12"
                    y2="4"></line></svg
                >
              </div>
              <h3
                class="text-base font-bold text-white font-mono i18n"
                data-i18n-es={es.integration.siren_title}
                data-i18n-en={en.integration.siren_title}
              >
                {es.integration.siren_title}
              </h3>
            </div>
            <p
              class="text-sm text-slate leading-[1.7] i18n"
              data-i18n-es={es.integration.siren_desc}
              data-i18n-en={en.integration.siren_desc}
            >
              {es.integration.siren_desc}
            </p>
            <!-- Mock alert panel -->
            <div
              class="mt-8 rounded-lg p-5"
              style="background:rgba(0,0,0,0.25);border:1px solid rgba(255,85,85,0.06);"
            >
              <div class="flex items-center gap-3 mb-3">
                <div
                  class="w-2 h-2 rounded-full bg-[#FF5555]"
                  style="animation:pulse-siren 1.2s ease-in-out infinite;"
                >
                </div>
                <span
                  class="font-mono text-[10px] text-[#FF5555] tracking-wider"
                  >ALERTA ACTIVA</span
                >
              </div>
              <div class="font-mono text-xs text-white-soft">
                🔊 Sirena encendida — Faroles ON
              </div>
              <div class="font-mono text-[10px] text-ghost mt-1.5">
                Zona A | Duración: 30s | 20:45:03
              </div>
            </div>
          </div>
          <!-- Dashboard -->
          <div class="glass-card hud-border p-10 integ-card">
            <div class="flex items-center gap-4 mb-5">
              <div
                class="w-10 h-10 rounded flex items-center justify-center"
                style="background:rgba(138,100,255,0.06);border:1px solid rgba(138,100,255,0.15);"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#8A64FF"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect
                    x="14"
                    y="3"
                    width="7"
                    height="7"
                    rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"
                  ></rect><rect x="14" y="14" width="7" height="7" rx="1"
                  ></rect></svg
                >
              </div>
              <h3
                class="text-base font-bold text-white font-mono i18n"
                data-i18n-es={es.integration.dashboard_title}
                data-i18n-en={en.integration.dashboard_title}
              >
                {es.integration.dashboard_title}
              </h3>
            </div>
            <p
              class="text-sm text-slate leading-[1.7] i18n"
              data-i18n-es={es.integration.dashboard_desc}
              data-i18n-en={en.integration.dashboard_desc}
            >
              {es.integration.dashboard_desc}
            </p>
            <!-- Mock stats panel -->
            <div
              class="mt-8 rounded-lg p-5"
              style="background:rgba(0,0,0,0.25);border:1px solid rgba(138,100,255,0.06);"
            >
              <div class="grid grid-cols-3 gap-4 text-center">
                <div>
                  <div class="font-mono text-lg text-white font-bold">847</div>
                  <div class="font-mono text-[10px] text-ghost">
                    Detecciones
                  </div>
                </div>
                <div>
                  <div class="font-mono text-lg text-white font-bold">
                    99.1%
                  </div>
                  <div class="font-mono text-[10px] text-ghost">Precisión</div>
                </div>
                <div>
                  <div class="font-mono text-lg text-white font-bold">24/7</div>
                  <div class="font-mono text-[10px] text-ghost">Activo</div>
                </div>
              </div>
            </div>
          </div>
